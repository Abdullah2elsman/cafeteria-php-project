# Turn on the rewrite engine
RewriteEngine On

# 1. Protection: Prevent people from browsing your folders
Options -Indexes

# 2. Redirect to 'public' folder if the user hits the root
# (Optional: If your index.php is inside a /public folder)
RewriteRule ^$ index.php [L]

# 3. The Core Logic:
# If the requested filename is NOT a real file (-f)
# And the requested filename is NOT a real directory (-d)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# 4. Rewrite everything else to index.php
# QSA means "Query String Append" (keeps extra variables)
# L means "Last" (stop processing further rules)
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]